{% if html_meta.open_graph %}
    {% if html_meta.open_graph.locale %}
        <meta name ="og:locale" value="{{ html_meta.open_graph.locale }}" />
    {% endif %}
    {% if html_meta.open_graph.type %}
        <meta name ="og:type" value="{{ html_meta.open_graph.type }}" />
    {% endif %}
    {% if html_meta.open_graph.title %}
        <meta name ="og:title" value="{{ html_meta.open_graph.title }}" />
    {% endif %}
    {% if html_meta.open_graph.description %}
        <meta name ="og:description" value="{{ html_meta.open_graph.description }}" />
    {% endif %}
    {% if html_meta.open_graph.article_published_time %}
        <meta name ="article:published_time" value="{{ html_meta.open_graph.article_published_time.format('Y-m-d\\TH:i:sP') }}" />
    {% endif %}
    {% if html_meta.open_graph.site_name %}
        <meta name ="og:site_name" value="{{ html_meta.open_graph.site_name }}" />
    {% endif %}
    {% if html_meta.open_graph.url %}
        <meta name ="og:url" value="{{ html_meta.open_graph.url }}" />
    {% endif %}
{% endif %}
